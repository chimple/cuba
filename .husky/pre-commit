if git diff --cached --unified=0 -- ":(glob)**/*.ts" ":(glob)**/*.tsx" | grep -E '^\+[^+].*\bas[[:space:]]+any\b' > /dev/null; then
  echo "[Husky Hook] Staged TypeScript changes contain 'as any'. Please replace it before committing."
  exit 1
fi

npx.cmd lint-staged || {
  echo "[Husky Hook] Linting or formatting failed! Please run 'npm run fix-staged' to automatically fix ONLY your staged files, then try committing again.";
  exit 1;
}
