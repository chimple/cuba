{
  "hosting": {
    "public": "build",
    "site": "test-9ea33",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**/*.js",
        "destination": "**/*.js"
      },
      {
        "source": "**/*.jsc",
        "destination": "**/*.jsc"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.jsc",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/javascript"
          }
        ]
      }
    ]
  }
}
